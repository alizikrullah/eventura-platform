// Eventura Platform Database Schema - UPDATED FOR MIDTRANS
// PostgreSQL via Neon

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  customer
  organizer
}

enum DiscountType {
  percentage
  fixed
}

enum TransactionStatus {
  waiting_payment
  paid
  expired
  canceled
}

enum PointSource {
  referral_reward
  transaction_usage
  transaction_refund
}

model User {
  id              Int      @id @default(autoincrement())
  email           String   @unique
  password        String
  name            String
  role            Role     @default(customer)
  referral_code   String   @unique
  profile_picture String?
  phone           String?
  is_verified     Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  organized_events Event[]
  transactions     Transaction[]
  reviews          Review[]
  user_coupons     UserCoupon[]
  points           Point[]
  referrals_given  Referral[]     @relation("Referrer")
  referrals_used   Referral[]     @relation("Referee")

  @@index([email])
  @@index([referral_code])
  @@index([role])
  @@map("users")
}

model Category {
  id         Int      @id @default(autoincrement())
  name       String
  slug       String   @unique
  created_at DateTime @default(now())

  // Relations
  events Event[]

  @@map("categories")
}

model Event {
  id              Int      @id @default(autoincrement())
  organizer_id    Int
  category_id     Int?
  name            String
  description     String?  @db.Text
  location        String
  venue           String?
  total_seats     Int
  available_seats Int
  start_date      DateTime
  end_date        DateTime
  image_url       String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  organizer       User          @relation(fields: [organizer_id], references: [id])
  category        Category?     @relation(fields: [category_id], references: [id])
  ticket_types    TicketType[]
  vouchers        Voucher[]
  transactions    Transaction[]
  reviews         Review[]

  @@index([organizer_id])
  @@index([category_id])
  @@index([location, category_id])
  @@index([start_date])
  @@index([is_active])
  @@map("events")
}

model TicketType {
  id                 Int      @id @default(autoincrement())
  event_id           Int
  name               String
  price              Int
  quantity           Int
  available_quantity Int
  description        String?  @db.Text
  created_at         DateTime @default(now())

  // Relations
  event             Event             @relation(fields: [event_id], references: [id])
  transaction_items TransactionItem[]

  @@index([event_id])
  @@map("ticket_types")
}

model Voucher {
  id             Int          @id @default(autoincrement())
  event_id       Int
  code           String       @unique
  discount_type  DiscountType
  discount_value Int
  max_usage      Int?
  current_usage  Int          @default(0)
  start_date     DateTime
  end_date       DateTime
  is_active      Boolean      @default(true)
  created_at     DateTime     @default(now())

  // Relations
  event        Event         @relation(fields: [event_id], references: [id])
  transactions Transaction[]

  @@index([event_id])
  @@index([code])
  @@index([start_date, end_date])
  @@map("vouchers")
}

model Coupon {
  id             Int          @id @default(autoincrement())
  code           String       @unique
  discount_type  DiscountType
  discount_value Int
  created_at     DateTime     @default(now())

  // Relations
  user_coupons UserCoupon[]

  @@map("coupons")
}

model UserCoupon {
  id         Int       @id @default(autoincrement())
  user_id    Int
  coupon_id  Int
  is_used    Boolean   @default(false)
  used_at    DateTime?
  expired_at DateTime
  created_at DateTime  @default(now())

  // Relations
  user         User          @relation(fields: [user_id], references: [id])
  coupon       Coupon        @relation(fields: [coupon_id], references: [id])
  transactions Transaction[]

  @@index([user_id])
  @@index([user_id, is_used, expired_at])
  @@map("user_coupons")
}


model Point {
  id               Int         @id @default(autoincrement())
  user_id          Int
  amount           Int         // total amount credited
  amount_remaining Int         // remaining balance (allows partial usage)
  source           PointSource
  reference_id     Int?        // transaction_id or referral user_id
  expired_at       DateTime    // 3 months from created_at
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt

  // Relations
  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([user_id, expired_at])
  @@map("points")
}

// ✅ UPDATED: Midtrans integration fields
model Transaction {
  id                 Int               @id @default(autoincrement())
  user_id            Int
  event_id           Int
  voucher_id         Int?
  user_coupon_id     Int?
  invoice_number     String            @unique
  snap_token         String?           // ✅ NEW - Midtrans Snap token
  midtrans_order_id  String?           // ✅ NEW - Midtrans order ID
  total_ticket_price Int
  voucher_discount   Int               @default(0)
  coupon_discount    Int               @default(0)
  points_used        Int               @default(0)
  final_price        Int
  status             TransactionStatus @default(waiting_payment)
  paid_at            DateTime?         // timestamp when payment is first confirmed
  payment_expired_at DateTime?         // 2 hours from created_at
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt

  // Relations
  user              User              @relation(fields: [user_id], references: [id])
  event             Event             @relation(fields: [event_id], references: [id])
  voucher           Voucher?          @relation(fields: [voucher_id], references: [id])
  user_coupon       UserCoupon?       @relation(fields: [user_coupon_id], references: [id])
  transaction_items TransactionItem[]
  review            Review?

  @@index([user_id])
  @@index([event_id])
  @@index([invoice_number])
  @@index([status])
  @@index([status, paid_at])
  @@index([status, payment_expired_at])
  @@map("transactions")
}

model TransactionItem {
  id             Int        @id @default(autoincrement())
  transaction_id Int
  ticket_type_id Int?
  ticket_name    String
  quantity       Int
  price          Int
  subtotal       Int
  created_at     DateTime   @default(now())

  // Relations
  transaction Transaction @relation(fields: [transaction_id], references: [id])
  ticket_type TicketType? @relation(fields: [ticket_type_id], references: [id])

  @@index([transaction_id])
  @@map("transaction_items")
}

model Review {
  id             Int      @id @default(autoincrement())
  event_id       Int
  user_id        Int
  transaction_id Int      @unique
  rating         Int
  comment        String?  @db.Text
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  // Relations
  event       Event       @relation(fields: [event_id], references: [id])
  user        User        @relation(fields: [user_id], references: [id])
  transaction Transaction @relation(fields: [transaction_id], references: [id])

  @@index([event_id])
  @@index([user_id])
  @@index([event_id, rating])
  @@map("reviews")
}

model Referral {
  id             Int      @id @default(autoincrement())
  referrer_id    Int
  referee_id     Int      @unique
  points_awarded Boolean  @default(false)
  coupon_awarded Boolean  @default(false)
  created_at     DateTime @default(now())

  // Relations
  referrer User @relation("Referrer", fields: [referrer_id], references: [id])
  referee  User @relation("Referee", fields: [referee_id], references: [id])

  @@index([referrer_id])
  @@map("referrals")
}
